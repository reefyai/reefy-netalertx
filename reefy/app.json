{
  "slug": "netalertx",
  "version": "25.11",
  "name": "NetAlertX",
  "icon": "icon.png",
  "description": "LAN asset monitor with device discovery, history, alerts, and a richer web UI.",
  "image": "ghcr.io/jokob-sk/netalertx:25.11",
  "default_port": 20211,
  "network_mode": "host",
  "needs_llm": false,
  "entrypoint": [
    "/bin/sh",
    "-lc"
  ],
  "command": [
    "mkdir -p /data/config /data/db; if [ ! -f /data/config/app.conf ]; then cp /app/back/app.conf /data/config/app.conf; fi; chmod u+rw /data/config/app.conf; exec /entrypoint.sh"
  ],
  "read_only": true,
  "cap_drop": [
    "ALL"
  ],
  "cap_add": [
    "NET_ADMIN",
    "NET_RAW",
    "NET_BIND_SERVICE"
  ],
  "tmpfs": [
    "/tmp:mode=1777,uid=0,gid=0,rw,noexec,nosuid,nodev,async,noatime,nodiratime"
  ],
  "mem_limit": "2048m",
  "mem_reservation": "1024m",
  "cpu_shares": 512,
  "pids_limit": 512,
  "volumes": {
    "data": {
      "mount": "/data",
      "uid": 20211,
      "backup": [
        "borgbase"
      ]
    }
  },
  "env": {
    "TZ": "Etc/UTC",
    "PUID": "20211",
    "PGID": "20211",
    "LISTEN_ADDR": "0.0.0.0",
    "PORT": "20211",
    "GRAPHQL_PORT": "20212",
    "ALWAYS_FRESH_INSTALL": "false",
    "NETALERTX_DEBUG": "0"
  },
  "tags": [
    "network",
    "monitoring"
  ]
}

